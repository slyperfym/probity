# Arc testnet frontend environment template.
# Values below are placeholders. Replace them with official Arc testnet metadata
# and deployed Probity contract addresses before using this target.

NEXT_PUBLIC_APP_URL=https://YOUR_VERCEL_PROJECT.vercel.app
NEXT_PUBLIC_DEPLOYMENT_TARGET=arc-testnet
NEXT_PUBLIC_MARKET_DATA_MODE=auto

# Arc testnet placeholders. Do not ship with local RPC values.
NEXT_PUBLIC_CHAIN_ID=
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_ARC_CHAIN_NAME=Arc Testnet
NEXT_PUBLIC_ARC_NATIVE_CURRENCY_NAME=
NEXT_PUBLIC_ARC_NATIVE_CURRENCY_SYMBOL=
NEXT_PUBLIC_ARC_BLOCK_EXPLORER_URL=

# Required for deployed contract-backed reads/writes.
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=
NEXT_PUBLIC_SETTLEMENT_TOKEN_ADDRESS=

# Required for WalletConnect mobile/deep-link support.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
