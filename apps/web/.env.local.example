# Local frontend environment for Next.js.
# Copy this file to apps/web/.env.local when you want explicit local settings.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ARC_CHAIN_NAME=Anvil
NEXT_PUBLIC_ARC_NATIVE_CURRENCY_NAME=Anvil Ether
NEXT_PUBLIC_ARC_NATIVE_CURRENCY_SYMBOL=ETH
NEXT_PUBLIC_ARC_BLOCK_EXPLORER_URL=
NEXT_PUBLIC_DEPLOYMENT_TARGET=local
NEXT_PUBLIC_ENABLE_MOCK_MARKETS=false

# Mock market summaries are disabled by default. Set NEXT_PUBLIC_ENABLE_MOCK_MARKETS=true
# only for explicit local/demo development.
NEXT_PUBLIC_MARKET_DATA_MODE=auto

# Optional overrides. If blank, apps/web/config/contracts.ts reads deployments/local/addresses.json.
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=
NEXT_PUBLIC_SETTLEMENT_TOKEN_ADDRESS=
