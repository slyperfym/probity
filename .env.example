# Shared public frontend configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ARC_CHAIN_NAME=Arc Testnet
NEXT_PUBLIC_ARC_NATIVE_CURRENCY_NAME=Arc Gas
NEXT_PUBLIC_ARC_NATIVE_CURRENCY_SYMBOL=ARC
NEXT_PUBLIC_ARC_BLOCK_EXPLORER_URL=
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=
NEXT_PUBLIC_SETTLEMENT_TOKEN_ADDRESS=
NEXT_PUBLIC_DEPLOYMENT_TARGET=local
NEXT_PUBLIC_MARKET_DATA_MODE=auto
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069

# Deployment target options:
# - mock: frontend/demo mode only, no contract reads or writes
# - local: Anvil + deployments/local/addresses.json
# - arc-testnet: Arc testnet RPC + deployments/arc-testnet/addresses.json or env address overrides
#
# Settlement token strategy:
# - local uses MockUSDC deployed by Foundry scripts
# - arc-testnet should use an official/user-provided USDC-style test token address
# - Arc testnet public demos should set SETTLEMENT_TOKEN_ADDRESS and NEXT_PUBLIC_SETTLEMENT_TOKEN_ADDRESS
# - do not configure a production USDC address for MVP testing

# Contract deployment configuration
RPC_URL=http://127.0.0.1:8545
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
LOCAL_PRIVATE_KEY=
PRIVATE_KEY=
ADMIN_ADDRESS=
RESOLVER_ADDRESS=
SETTLEMENT_TOKEN_ADDRESS=
MARKET_FACTORY_ADDRESS=
SEED_DEMO_MARKETS=0
FORCE_SEED_MARKETS=0
EXPLORER_API_KEY=

# Never commit a real PRIVATE_KEY. Use a dedicated testnet deployer wallet only.
